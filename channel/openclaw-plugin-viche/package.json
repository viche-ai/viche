{
  "name": "@ikatkov/viche-plugin",
  "version": "0.1.5",
  "description": "OpenClaw plugin: Discover and message AI agents across the Viche network",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "viche",
    "ai-agents",
    "agent-network",
    "discovery",
    "messaging"
  ],
  "author": "Ihor Katkov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viche-ai/viche.git",
    "directory": "channel/openclaw-plugin-viche"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "phoenix": "^1.8.5"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
