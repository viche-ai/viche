#!/usr/bin/env bash
set -euo pipefail

export MIX_ENV=test

echo "🔍 Running mix precommit..."

if mix precommit; then
  echo "✅ mix precommit passed — proceeding with commit."
else
  echo ""
  echo "❌ mix precommit failed — commit blocked."
  echo "   Fix the issues above, then try again."
  exit 1
fi
