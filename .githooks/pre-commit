#!/usr/bin/env sh
# Pre-commit hook: Elixir checks + conditional plugin checks + bd delegation
set -e

# --- Elixir checks ---
if command -v mix >/dev/null 2>&1; then
    echo "Running mix precommit (compile, format, credo, test, dialyzer)..."
    if ! mix precommit; then
        echo ""
        echo "Error: mix precommit failed. Fix issues and try again." >&2
        exit 1
    fi
else
    echo "Warning: mix not found, skipping Elixir checks" >&2
fi

# --- OpenClaw plugin checks ---
if git diff --cached --name-only | grep -q '^channel/openclaw-plugin-viche/'; then
    echo "Staged changes in openclaw-plugin-viche detected — running checks..."
    (
        cd channel/openclaw-plugin-viche
        npm ci
        npx tsc --noEmit
        npm run build
    )
    echo "OpenClaw plugin checks passed."
fi

# --- OpenCode plugin checks ---
if git diff --cached --name-only | grep -q '^channel/opencode-plugin-viche/'; then
    echo "Staged changes in opencode-plugin-viche detected — running checks..."
    (
        cd channel/opencode-plugin-viche
        bun install
        bunx tsc --noEmit
        bun run build
        bun run test
    )
    echo "OpenCode plugin checks passed."
fi

# --- bd delegation ---
if command -v bd >/dev/null 2>&1; then
    exec bd hook pre-commit "$@"
fi
