#!/usr/bin/env sh
set -e

# --- Elixir checks ---
if command -v mix >/dev/null 2>&1; then
    echo "==> Running Elixir pre-commit checks..."
    mix precommit
else
    echo "Warning: mix not found, skipping Elixir checks" >&2
fi

# --- OpenClaw plugin checks (only if files changed) ---
OPENCLAW_DIR="channel/openclaw-plugin-viche"
if git diff --cached --name-only | grep -q "^${OPENCLAW_DIR}/"; then
    echo "==> Running OpenClaw plugin checks..."
    (cd "$OPENCLAW_DIR" && npm ci && npx tsc --noEmit && npm run build)
fi

# --- OpenCode plugin checks (only if files changed) ---
OPENCODE_DIR="channel/opencode-plugin-viche"
if git diff --cached --name-only | grep -q "^${OPENCODE_DIR}/"; then
    echo "==> Running OpenCode plugin checks..."
    (cd "$OPENCODE_DIR" && bun install && bunx tsc --noEmit && bun run build && bun run test)
fi

# --- bd hook delegation ---
if command -v bd >/dev/null 2>&1; then
    exec bd hook pre-commit "$@"
fi
