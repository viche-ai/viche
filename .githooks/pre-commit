#!/bin/sh
# Pre-commit hook: runs plugin checks and `mix precommit` before every commit.
#
# This hook is version-controlled in .githooks/ and auto-configured by `mix setup`
# via: git config core.hooksPath .githooks

set -e

STAGED_FILES=$(git diff --cached --name-only)

# ── OpenCode plugin checks ────────────────────────────────────────────────────
if echo "$STAGED_FILES" | grep -q "^channel/opencode-plugin-viche/"; then
  echo "------------------------------------------------------------"
  echo "  Pre-commit: opencode-plugin-viche files changed"
  echo "  (bun install, tsc, build)"
  echo "------------------------------------------------------------"

  cd channel/opencode-plugin-viche

  echo "  → bun install --frozen-lockfile"
  if ! bun install --frozen-lockfile; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: bun install failed in opencode-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  echo "  → bunx tsc --noEmit"
  if ! bunx tsc --noEmit; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: TypeScript check failed in opencode-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  echo "  → bun run build"
  if ! bun run build; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: build failed in opencode-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  cd ../..
fi

echo "------------------------------------------------------------"
echo "  Pre-commit: running opencode-plugin-viche unit tests"
echo "------------------------------------------------------------"

cd channel/opencode-plugin-viche
echo "  → bun run test"
if ! bun run test; then
  echo ""
  echo "------------------------------------------------------------"
  echo "  BLOCKED: tests failed in opencode-plugin-viche."
  echo "------------------------------------------------------------"
  exit 1
fi
cd ../..

echo ""
echo "  opencode-plugin-viche checks passed."
echo "------------------------------------------------------------"

# ── OpenClaw plugin checks ────────────────────────────────────────────────────
if echo "$STAGED_FILES" | grep -q "^channel/openclaw-plugin-viche/"; then
  echo "------------------------------------------------------------"
  echo "  Pre-commit: openclaw-plugin-viche files changed"
  echo "  (npm install, tsc, build)"
  echo "------------------------------------------------------------"

  cd channel/openclaw-plugin-viche

  echo "  → npm install"
  if ! npm install; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: npm install failed in openclaw-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  echo "  → npx tsc --noEmit"
  if ! npx tsc --noEmit; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: TypeScript check failed in openclaw-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  echo "  → npm run build"
  if ! npm run build; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: build failed in openclaw-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  cd ../..
fi

echo "------------------------------------------------------------"
echo "  Pre-commit: running openclaw-plugin-viche unit tests"
echo "------------------------------------------------------------"

cd channel/openclaw-plugin-viche
echo "  → npm test"
if ! npm test; then
  echo ""
  echo "------------------------------------------------------------"
  echo "  BLOCKED: tests failed in openclaw-plugin-viche."
  echo "------------------------------------------------------------"
  exit 1
fi
cd ../..

echo ""
echo "  openclaw-plugin-viche checks passed."
echo "------------------------------------------------------------"

# ── Claude Code plugin checks ─────────────────────────────────────────────────
if echo "$STAGED_FILES" | grep -q "^channel/claude-code-plugin-viche/"; then
  echo "------------------------------------------------------------"
  echo "  Pre-commit: claude-code-plugin-viche files changed"
  echo "  (bun install, tsc)"
  echo "------------------------------------------------------------"

  cd channel/claude-code-plugin-viche

  echo "  → bun install --frozen-lockfile"
  if ! bun install --frozen-lockfile; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: bun install failed in claude-code-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  echo "  → bunx tsc --noEmit"
  if ! bunx tsc --noEmit; then
    echo ""
    echo "------------------------------------------------------------"
    echo "  BLOCKED: TypeScript check failed in claude-code-plugin-viche."
    echo "------------------------------------------------------------"
    exit 1
  fi

  cd ../..
fi

echo "------------------------------------------------------------"
echo "  Pre-commit: running claude-code-plugin-viche unit tests"
echo "------------------------------------------------------------"

cd channel/claude-code-plugin-viche
echo "  → bun test tools.test.ts"
if ! bun test tools.test.ts; then
  echo ""
  echo "------------------------------------------------------------"
  echo "  BLOCKED: unit tests failed in claude-code-plugin-viche."
  echo "------------------------------------------------------------"
  exit 1
fi
cd ../..

echo ""
echo "  claude-code-plugin-viche checks passed."
echo "------------------------------------------------------------"

# ── Elixir checks ─────────────────────────────────────────────────────────────
echo "------------------------------------------------------------"
echo "  Pre-commit: running mix precommit"
echo "  (compile, deps check, format, credo, tests, dialyzer)"
echo "------------------------------------------------------------"

if ! mix precommit; then
  echo ""
  echo "------------------------------------------------------------"
  echo "  BLOCKED: pre-commit validation failed."
  echo "  Fix the issues above, then try committing again."
  echo "------------------------------------------------------------"
  exit 1
fi

echo ""
echo "------------------------------------------------------------"
echo "  Pre-commit validation passed. Proceeding with commit."
echo "------------------------------------------------------------"
