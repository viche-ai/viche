# Viche Self-Hosting Environment Variables
# Copy to .env and adjust for your deployment.

# REQUIRED — app will not start without these in production
SECRET_KEY_BASE=change-me-generate-with-mix-phx.gen.secret
DATABASE_URL=ecto://postgres:postgres@db/viche_prod

# Domain / URL — used for generating links, emails, and the well-known descriptor
PHX_HOST=localhost
PORT=4000
PHX_SERVER=true

# Authentication — set to true to require login for the UI
REQUIRE_AUTH=false

# Registry mode — true shows registry selector in sidebar
VICHE_PUBLIC_MODE=true

# Analytics — set to false to disable Simple Analytics tracking
VICHE_ANALYTICS=false

# Telemetry — set to false to opt out of sending anonymized usage stats to viche.ai
# Only aggregate counts are sent (agent count, messages, version, uptime). No PII.
# VICHE_TELEMETRY=false

# Email provider: "resend", "console" (logs to stdout), or unset (in-memory)
EMAIL_PROVIDER=console
# RESEND_API_KEY=re_xxxxxxxx  # only needed if EMAIL_PROVIDER=resend

# Email sender (optional) — format: "Name <address>" or just "address"
# EMAIL_FROM=Viche <noreply@yourdomain.com>
