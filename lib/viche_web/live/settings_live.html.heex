<div style="background:var(--bg);color:var(--fg)" class="flex h-screen overflow-hidden">
  <%!-- SIDEBAR --%>
  <aside
    style="background:var(--bg-1);border-right:1px solid var(--border)"
    class="w-[216px] min-w-[216px] flex flex-col"
  >
    <%!-- Logo --%>
    <div class="px-4 py-4 flex items-center gap-2">
      <div class="w-7 h-7 rounded-md overflow-hidden flex-shrink-0">
        <img src="/images/viche-logo.png" alt="Viche" class="w-full h-full object-cover" />
      </div>
      <span class="text-[15px] font-semibold tracking-tight" style="color:var(--fg)">Viche</span>
      <span class="text-[10px] font-mono ml-auto" style="color:var(--fg-dim)">v0.1.0-alpha</span>
    </div>

    <%!-- Nav --%>
    <nav class="flex-1 flex flex-col px-2 gap-0.5 mt-1">
      <.link navigate="/" class="nav-item">
        <.icon name="hero-squares-2x2-micro" class="size-4" />
        <span>Dashboard</span>
      </.link>

      <.link navigate="/network" class="nav-item">
        <.icon name="hero-signal-micro" class="size-4" />
        <span>Network</span>
      </.link>

      <div class="my-1 mx-2" style="border-top:1px solid var(--border)"></div>

      <div class="px-2 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider" style="color:var(--fg-dim)">
        Agents
      </div>

      <.link navigate="/agents" class="nav-item">
        <.icon name="hero-users-micro" class="size-4" />
        <span class="flex-1">All Agents</span>
        <span class="text-[10px] font-mono px-1.5 rounded ml-auto" style="background:var(--bg-2);color:var(--fg-dim)">{@agent_count}</span>
      </.link>

      <.link navigate="/sessions" class="nav-item">
        <.icon name="hero-envelope-micro" class="size-4" />
        <span>Inboxes</span>
      </.link>

      <div class="my-1 mx-2" style="border-top:1px solid var(--border)"></div>

      <div class="px-2 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider" style="color:var(--fg-dim)">
        Demo
      </div>

      <.link navigate="/demo" class="nav-item">
        <.icon name="hero-presentation-chart-bar-micro" class="size-4" />
        <span>Network Demo</span>
      </.link>

      <.link navigate="/join/demo" class="nav-item">
        <.icon name="hero-link-micro" class="size-4" />
        <span>Join</span>
      </.link>

      <div class="flex-1"></div>

      <div class="nav-item active" style="border-left:2px solid var(--color-ef-green);padding-left:6px">
        <.icon name="hero-cog-6-tooth-micro" class="size-4" />
        <span>Settings</span>
      </div>

      <a
        href="https://github.com/ihorkatkov/viche"
        target="_blank"
        rel="noopener"
        class="nav-item mb-2"
      >
        <.icon name="hero-code-bracket-micro" class="size-4" />
        <span>GitHub</span>
      </a>
    </nav>
  </aside>

  <%!-- MAIN --%>
  <main class="flex-1 flex flex-col overflow-hidden">
    <%!-- TOPBAR --%>
    <div
      class="h-[50px] flex items-center px-5 gap-3 border-b flex-shrink-0"
      style="background:var(--bg-1);border-color:var(--border)"
    >
      <span class="text-[15px] font-semibold" style="color:var(--fg)">Settings</span>
      <span class="text-[13px]" style="color:var(--fg-dim)">/ configuration</span>
      <div class="flex-1"></div>
      <Layouts.theme_toggle />
    </div>

    <%!-- CONTENT --%>
    <div class="flex-1 overflow-y-auto p-6" style="background:var(--bg)">
      <div class="max-w-[680px] space-y-5">
        <%!-- SECTION 1: Connection --%>
        <div class="rounded-xl p-5 space-y-4" style="background:var(--bg-1);border:1px solid var(--border)">
          <h2 class="text-[13px] font-semibold" style="color:var(--fg)">Connection</h2>

          <%!-- Registry URL --%>
          <div class="space-y-1.5">
            <label class="text-[11px] font-medium uppercase tracking-wide" style="color:var(--fg-dim)">Registry URL</label>
            <input
              type="text"
              value={@settings.registry_url}
              phx-change="field_changed"
              phx-value-field="registry_url"
              name="value"
              class="w-full px-3 py-2 rounded-lg text-[13px] outline-none"
              style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg)"
            />
            <p class="text-[11px]" style="color:var(--fg-dim)">The URL of your Viche registry instance</p>
          </div>

          <%!-- API Token --%>
          <div class="space-y-1.5">
            <label class="text-[11px] font-medium uppercase tracking-wide" style="color:var(--fg-dim)">API Token</label>
            <div class="flex gap-2">
              <input
                type={if @show_token, do: "text", else: "password"}
                value={@token}
                readonly
                class="flex-1 px-3 py-2 rounded-lg text-[13px] font-mono outline-none"
                style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg)"
              />
              <button
                phx-click="toggle_token_visibility"
                class="px-3 py-2 rounded-lg text-[11px] flex items-center gap-1.5"
                style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg-dim)"
              >
                <.icon name={if @show_token, do: "hero-eye-slash-micro", else: "hero-eye-micro"} class="size-3.5" />
                {if @show_token, do: "Hide", else: "Show"}
              </button>
            </div>
            <p class="text-[11px]" style="color:var(--fg-dim)">Your authentication token for the registry API</p>
          </div>

          <%!-- WebSocket URL --%>
          <div class="space-y-1.5">
            <label class="text-[11px] font-medium uppercase tracking-wide" style="color:var(--fg-dim)">WebSocket URL</label>
            <input
              type="text"
              value="wss://viche.fly.dev/socket/websocket"
              disabled
              class="w-full px-3 py-2 rounded-lg text-[13px] font-mono outline-none opacity-60"
              style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg-dim)"
            />
          </div>

          <%!-- Connection Status --%>
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
              <%= case @connection_status do %>
                <% :idle -> %>
                  <span class="w-2 h-2 rounded-full" style="background:var(--fg-dim)"></span>
                  <span class="text-[12px]" style="color:var(--fg-dim)">Not tested</span>
                <% :testing -> %>
                  <span class="w-2 h-2 rounded-full animate-pulse" style="background:var(--color-ef-yellow)"></span>
                  <span class="text-[12px]" style="color:var(--color-ef-yellow)">Testing...</span>
                <% :connected -> %>
                  <span class="w-2 h-2 rounded-full" style="background:var(--color-ef-green)"></span>
                  <span class="text-[12px]" style="color:var(--color-ef-green)">Connected ✓</span>
                <% :failed -> %>
                  <span class="w-2 h-2 rounded-full" style="background:var(--color-ef-red)"></span>
                  <span class="text-[12px]" style="color:var(--color-ef-red)">Connection failed</span>
              <% end %>
            </div>
            <div class="flex-1"></div>
            <button
              phx-click="test_connection"
              disabled={@connection_status == :testing}
              class="px-3 py-1.5 rounded-lg text-[11px] font-medium"
              style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg-dim)"
            >
              Test connection
            </button>
          </div>
        </div>

        <%!-- SECTION 2: Registry --%>
        <div class="rounded-xl p-5 space-y-4" style="background:var(--bg-1);border:1px solid var(--border)">
          <h2 class="text-[13px] font-semibold" style="color:var(--fg)">Registry</h2>

          <%!-- Namespace --%>
          <div class="space-y-1.5">
            <label class="text-[11px] font-medium uppercase tracking-wide" style="color:var(--fg-dim)">Namespace</label>
            <input
              type="text"
              value={@settings.namespace}
              phx-change="field_changed"
              phx-value-field="namespace"
              name="value"
              class="w-full px-3 py-2 rounded-lg text-[13px] outline-none"
              style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg)"
            />
          </div>

          <%!-- Agent Prefix --%>
          <div class="space-y-1.5">
            <label class="text-[11px] font-medium uppercase tracking-wide" style="color:var(--fg-dim)">Agent Prefix</label>
            <input
              type="text"
              value={@settings.agent_prefix}
              phx-change="field_changed"
              phx-value-field="agent_prefix"
              name="value"
              class="w-full px-3 py-2 rounded-lg text-[13px] outline-none"
              style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg)"
            />
          </div>

          <%!-- Auth Toggle --%>
          <div class="flex items-center justify-between">
            <div>
              <div class="text-[13px] font-medium" style="color:var(--fg)">Require Authentication</div>
              <div class="text-[11px]" style="color:var(--fg-dim)">Agents must provide a valid token to register</div>
            </div>
            <button
              phx-click="toggle_setting"
              phx-value-key="require_auth"
              class="relative w-10 h-5 rounded-full transition-colors"
              style={"background:#{if @settings.require_auth, do: "var(--color-ef-green)", else: "var(--bg-3, #475258)"}"}
            >
              <span
                class="absolute top-0.5 w-4 h-4 rounded-full transition-all"
                style={"background:white;#{if @settings.require_auth, do: "left:calc(100% - 18px)", else: "left:2px"}"}
              ></span>
            </button>
          </div>
        </div>

        <%!-- SECTION 3: Appearance --%>
        <div class="rounded-xl p-5 space-y-4" style="background:var(--bg-1);border:1px solid var(--border)">
          <h2 class="text-[13px] font-semibold" style="color:var(--fg)">Appearance</h2>

          <%!-- Theme Selector --%>
          <div class="flex gap-3">
            <div
              phx-click="select_theme"
              phx-value-theme="dark"
              class="flex-1 p-4 rounded-xl cursor-pointer flex flex-col gap-2"
              style={"#{if @theme == :dark, do: "border:1.5px solid var(--color-ef-green);background:var(--bg-2)", else: "border:1px solid var(--border);background:var(--bg-2)"}"}
            >
              <div class="flex gap-1.5">
                <span class="w-4 h-4 rounded-full" style="background:#2b3339"></span>
                <span class="w-4 h-4 rounded-full" style="background:#343f44"></span>
                <span class="w-4 h-4 rounded-full" style="background:#a7c080"></span>
                <span class="w-4 h-4 rounded-full" style="background:#d3c6aa"></span>
              </div>
              <span class="text-[12px] font-medium" style="color:var(--fg)">Dark</span>
            </div>
            <div
              phx-click="select_theme"
              phx-value-theme="light"
              class="flex-1 p-4 rounded-xl cursor-pointer flex flex-col gap-2"
              style={"#{if @theme == :light, do: "border:1.5px solid var(--color-ef-green);background:var(--bg-2)", else: "border:1px solid var(--border);background:var(--bg-2)"}"}
            >
              <div class="flex gap-1.5">
                <span class="w-4 h-4 rounded-full" style="background:#f3ead3"></span>
                <span class="w-4 h-4 rounded-full" style="background:#edeada"></span>
                <span class="w-4 h-4 rounded-full" style="background:#8da101"></span>
                <span class="w-4 h-4 rounded-full" style="background:#5c6a72"></span>
              </div>
              <span class="text-[12px] font-medium" style="color:var(--fg)">Light</span>
            </div>
          </div>

          <%!-- Live Feed Toggle --%>
          <div class="flex items-center justify-between">
            <div>
              <div class="text-[13px] font-medium" style="color:var(--fg)">Live Feed</div>
              <div class="text-[11px]" style="color:var(--fg-dim)">Show real-time activity updates</div>
            </div>
            <button
              phx-click="toggle_setting"
              phx-value-key="live_feed"
              class="relative w-10 h-5 rounded-full transition-colors"
              style={"background:#{if @settings.live_feed, do: "var(--color-ef-green)", else: "var(--bg-3, #475258)"}"}
            >
              <span
                class="absolute top-0.5 w-4 h-4 rounded-full transition-all"
                style={"background:white;#{if @settings.live_feed, do: "left:calc(100% - 18px)", else: "left:2px"}"}
              ></span>
            </button>
          </div>

          <%!-- Animate Graph Toggle --%>
          <div class="flex items-center justify-between">
            <div>
              <div class="text-[13px] font-medium" style="color:var(--fg)">Animate Graph</div>
              <div class="text-[11px]" style="color:var(--fg-dim)">Enable animations in the network graph</div>
            </div>
            <button
              phx-click="toggle_setting"
              phx-value-key="animate_graph"
              class="relative w-10 h-5 rounded-full transition-colors"
              style={"background:#{if @settings.animate_graph, do: "var(--color-ef-green)", else: "var(--bg-3, #475258)"}"}
            >
              <span
                class="absolute top-0.5 w-4 h-4 rounded-full transition-all"
                style={"background:white;#{if @settings.animate_graph, do: "left:calc(100% - 18px)", else: "left:2px"}"}
              ></span>
            </button>
          </div>
        </div>

        <%!-- SECTION 4: Danger Zone --%>
        <div class="rounded-xl p-5 space-y-4" style="background:var(--bg-1);border:1px solid color-mix(in srgb,var(--color-ef-red) 35%,transparent)">
          <h2 class="text-[13px] font-semibold" style="color:var(--color-ef-red)">Danger Zone</h2>

          <%!-- Clear all agent data --%>
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-[13px] font-medium" style="color:var(--fg)">Clear all agent data</div>
              <div class="text-[11px]" style="color:var(--fg-dim)">Remove all registered agents and their history</div>
            </div>
            <%= if @danger_confirm == :clear do %>
              <div class="flex items-center gap-2">
                <span class="text-[11px]" style="color:var(--color-ef-red)">Are you sure?</span>
                <button
                  phx-click="execute_danger"
                  phx-value-action="clear"
                  class="px-3 py-1.5 rounded-lg text-[11px] font-medium"
                  style="background:var(--color-ef-red);color:white"
                >
                  Confirm
                </button>
                <button
                  phx-click="cancel_danger"
                  class="px-3 py-1.5 rounded-lg text-[11px]"
                  style="background:var(--bg-2);color:var(--fg-dim)"
                >
                  Cancel
                </button>
              </div>
            <% else %>
              <button
                phx-click="confirm_danger"
                phx-value-action="clear"
                class="px-3 py-1.5 rounded-lg text-[11px] font-medium flex-shrink-0"
                style="background:color-mix(in srgb,var(--color-ef-red) 15%,transparent);color:var(--color-ef-red)"
              >
                Clear all agent data
              </button>
            <% end %>
          </div>

          <div style="border-top:1px solid var(--border)"></div>

          <%!-- Reset settings --%>
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-[13px] font-medium" style="color:var(--fg)">Reset settings</div>
              <div class="text-[11px]" style="color:var(--fg-dim)">Restore all settings to their default values</div>
            </div>
            <%= if @danger_confirm == :reset do %>
              <div class="flex items-center gap-2">
                <span class="text-[11px]" style="color:var(--color-ef-red)">Are you sure?</span>
                <button
                  phx-click="execute_danger"
                  phx-value-action="reset"
                  class="px-3 py-1.5 rounded-lg text-[11px] font-medium"
                  style="background:var(--color-ef-red);color:white"
                >
                  Confirm
                </button>
                <button
                  phx-click="cancel_danger"
                  class="px-3 py-1.5 rounded-lg text-[11px]"
                  style="background:var(--bg-2);color:var(--fg-dim)"
                >
                  Cancel
                </button>
              </div>
            <% else %>
              <button
                phx-click="confirm_danger"
                phx-value-action="reset"
                class="px-3 py-1.5 rounded-lg text-[11px] font-medium flex-shrink-0"
                style="background:color-mix(in srgb,var(--color-ef-red) 15%,transparent);color:var(--color-ef-red)"
              >
                Reset settings
              </button>
            <% end %>
          </div>
        </div>

        <%!-- Bottom spacer for unsaved bar --%>
        <div :if={@dirty} class="h-14"></div>
      </div>
    </div>

    <%!-- UNSAVED CHANGES BAR --%>
    <div
      :if={@dirty}
      class="fixed bottom-0 left-0 right-0 flex items-center justify-between px-6 py-3 z-50"
      style="background:var(--bg-1);border-top:1px solid var(--border)"
    >
      <span class="text-sm" style="color:var(--fg-dim)">You have unsaved changes</span>
      <div class="flex gap-3">
        <button
          phx-click="discard_changes"
          class="px-4 py-2 rounded-lg text-[12px] font-medium"
          style="background:var(--bg-2);border:1px solid var(--border);color:var(--fg-dim)"
        >
          Discard
        </button>
        <button
          phx-click="save_settings"
          class="px-4 py-2 rounded-lg text-[12px] font-medium"
          style="background:var(--color-ef-green);color:var(--color-ef-bg0, #2b3339)"
        >
          Save changes
        </button>
      </div>
    </div>

    <%!-- STATUS BAR --%>
    <div
      class="h-6 flex items-center px-4 gap-3 text-[10px] font-mono border-t flex-shrink-0"
      style="background:var(--bg-1);border-color:var(--border);color:var(--fg-dim)"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ef-green)] animate-pulse inline-block">
      </span>
      ws://viche.fly.dev/socket
      <span class="opacity-30">|</span>
      registry: public
      <span class="opacity-30">|</span>
      {@agent_count} agents &middot; {@online_count} online
      <span class="opacity-30">|</span>
      {@messages_today} messages today
    </div>
  </main>
</div>
