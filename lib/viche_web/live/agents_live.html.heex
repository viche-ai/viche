<div style="background:var(--bg);color:var(--fg)" class="flex h-screen overflow-hidden">
  <Layouts.sidebar
    active_page={:agents}
    selected_registry={@selected_registry}
    registries={@registries}
    public_mode={@public_mode}
    mobile_menu_open={@mobile_menu_open}
    agent_count={@agent_count}
  />

  <%!-- MAIN --%>
  <main class="flex-1 flex flex-col overflow-hidden min-w-0">
    <%!-- TOPBAR --%>
    <div
      class="h-[50px] flex items-center px-3 md:px-5 gap-2 md:gap-3 border-b flex-shrink-0"
      style="background:var(--bg-1);border-color:var(--border)"
    >
      <%!-- Hamburger: mobile only --%>
      <button
        class="md:hidden flex items-center justify-center w-8 h-8 rounded-md flex-shrink-0"
        style="color:var(--fg-dim)"
        phx-click="toggle_mobile_menu"
        aria-label="Open menu"
      >
        <.icon name="hero-bars-3-micro" class="size-5" />
      </button>
      <span class="text-[15px] font-semibold" style="color:var(--fg)">Agents</span>
      <span class="text-[13px] hidden sm:inline" style="color:var(--fg-dim)">/ all</span>
      <div class="flex-1"></div>
      <span class="flex items-center gap-1.5 text-[11px]" style="color:var(--color-ef-green)">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ef-green)] animate-pulse inline-block">
        </span>
        Live
      </span>
      <Layouts.theme_toggle />
    </div>

    <%!-- SEARCH / FILTER BAR --%>
    <div
      class="flex items-center p-2 md:p-3 gap-2 md:gap-3"
      style="border-bottom:1px solid var(--border)"
    >
      <form phx-change="search" class="flex-1">
        <input
          type="text"
          name="value"
          value={@query}
          phx-debounce="200"
          placeholder="Search agents..."
          class="w-full rounded-lg px-3 py-1.5 text-sm outline-none"
          style="background:var(--bg-2);color:var(--fg);border:1px solid var(--border)"
        />
      </form>

      <%= for {label, str_val, atom_val} <- [{"All", "all", :all}, {"Online", "online", :online}, {"Offline", "offline", :offline}] do %>
        <button
          phx-click="filter"
          phx-value-status={str_val}
          class="text-[11px] px-2 md:px-3 py-1 rounded-full font-medium transition-colors flex-shrink-0"
          style={
            if @filter == atom_val,
              do:
                "background:color-mix(in srgb,var(--color-ef-green) 20%,transparent);color:var(--color-ef-green);border:1px solid var(--color-ef-green)",
              else: "background:var(--bg-2);color:var(--fg-dim);border:1px solid var(--border)"
          }
        >
          {label}
        </button>
      <% end %>
    </div>

    <%!-- CONTENT --%>
    <div class="flex-1 overflow-y-auto" style="background:var(--bg)">
      <%!-- Table header: desktop (7 cols) --%>
      <div
        class="hidden md:grid grid-cols-[28px_1fr_auto_90px_52px_80px_70px] gap-3 items-center px-4 py-2 text-[10px] font-semibold uppercase tracking-wide"
        style="background:var(--bg-2);color:var(--fg-dim)"
      >
        <span></span>
        <span>Agent</span>
        <span>Capabilities</span>
        <span>Status</span>
        <span>Queue</span>
        <span>Last seen</span>
        <span>Registry</span>
      </div>

      <%!-- Table header: mobile (2 cols) --%>
      <div
        class="md:hidden grid grid-cols-[1fr_80px] gap-2 items-center px-3 py-2 text-[10px] font-semibold uppercase tracking-wide"
        style="background:var(--bg-2);color:var(--fg-dim)"
      >
        <span>Agent</span>
        <span>Status</span>
      </div>

      <%!-- Table rows --%>
      <%= if @agents == [] do %>
        <div class="px-4 py-12 text-center text-[12px]" style="color:var(--fg-dim)">
          No agents match the current filters.
        </div>
      <% else %>
        <%= for agent <- @agents do %>
          <% avatar_colors = [
            "var(--color-ef-green)",
            "var(--color-ef-blue)",
            "var(--color-ef-purple)",
            "var(--color-ef-yellow)",
            "var(--color-ef-aqua)"
          ]

          avatar_color = Enum.at(avatar_colors, rem(:erlang.phash2(agent.name), 5))
          initial = (agent.name || "?") |> String.first() |> String.upcase() %>

          <%!-- Desktop row --%>
          <div
            phx-click="select_agent"
            phx-value-id={agent.id}
            class="hidden md:grid grid-cols-[28px_1fr_auto_90px_52px_80px_70px] gap-3 items-center px-4 py-2.5 cursor-pointer transition-colors"
            style="border-top:1px solid var(--border)"
          >
            <div
              class="w-7 h-7 rounded-md flex items-center justify-center text-[11px] font-bold flex-shrink-0"
              style={"background:color-mix(in srgb, #{avatar_color} 20%, transparent);color:#{avatar_color}"}
            >
              {initial}
            </div>
            <div class="min-w-0">
              <div class="text-[13px] font-medium truncate" style="color:var(--fg)">
                {agent.name}
              </div>
              <div class="text-[10px] font-mono truncate" style="color:var(--fg-dim)">
                {String.slice(agent.id, 0, 8)}
              </div>
            </div>
            <div class="flex gap-1 flex-wrap">
              <%= for cap <- agent.capabilities do %>
                <span class="cap-tag">{cap}</span>
              <% end %>
            </div>
            <span class={"status-pill #{if agent.status == :online, do: "idle", else: "offline"}"}>
              {agent.status}
            </span>
            <span class="text-[12px] font-mono" style="color:var(--fg-dim)">
              {agent.queue_depth}
            </span>
            <span class="text-[11px]" style="color:var(--fg-dim)">
              {VicheWeb.LiveHelpers.format_last_seen(agent.last_activity)}
            </span>
            <span class="text-[11px]" style="color:var(--fg-dim)">global</span>
          </div>

          <%!-- Mobile row --%>
          <div
            phx-click="select_agent"
            phx-value-id={agent.id}
            class="md:hidden grid grid-cols-[1fr_80px] gap-2 items-center px-3 py-2.5 cursor-pointer transition-colors"
            style="border-top:1px solid var(--border)"
          >
            <div class="flex items-center gap-2 min-w-0">
              <div
                class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold flex-shrink-0"
                style={"background:color-mix(in srgb, #{avatar_color} 20%, transparent);color:#{avatar_color}"}
              >
                {initial}
              </div>
              <div class="min-w-0">
                <div class="text-[12px] font-medium truncate" style="color:var(--fg)">
                  {agent.name}
                </div>
                <div class="text-[10px] font-mono truncate" style="color:var(--fg-dim)">
                  {String.slice(agent.id, 0, 8)}
                </div>
              </div>
            </div>
            <span class={"status-pill #{if agent.status == :online, do: "idle", else: "offline"}"}>
              {agent.status}
            </span>
          </div>
        <% end %>
      <% end %>

      <%!-- Footer --%>
      <div
        class="px-3 py-3 text-[11px]"
        style="color:var(--fg-dim);border-top:1px solid var(--border)"
      >
        Showing {length(@agents)} of {@agent_count} agents
      </div>
    </div>

    <Layouts.status_bar
      hosted={@hosted}
      selected_registry={@selected_registry}
      agent_count={@agent_count}
    />
  </main>
</div>
