<div style="background:var(--bg);color:var(--fg)" class="flex h-screen overflow-hidden">
  <%!-- SIDEBAR --%>
  <aside
    style="background:var(--bg-1);border-right:1px solid var(--border)"
    class="w-[216px] min-w-[216px] flex flex-col"
  >
    <%!-- Logo --%>
    <div class="px-4 py-4 flex items-center gap-2">
      <div class="w-7 h-7 rounded-md overflow-hidden flex-shrink-0">
        <img src="/images/viche-logo.png" alt="Viche" class="w-full h-full object-cover" />
      </div>
      <span class="text-[15px] font-semibold tracking-tight" style="color:var(--fg)">Viche</span>
      <span class="text-[10px] font-mono ml-auto" style="color:var(--fg-dim)">v0.1.0-alpha</span>
    </div>

    <%!-- Nav --%>
    <nav class="flex-1 flex flex-col px-2 gap-0.5 mt-1">
      <.link navigate="/" class="nav-item">
        <.icon name="hero-squares-2x2-micro" class="size-4" />
        <span>Dashboard</span>
      </.link>

      <.link navigate="/network" class="nav-item">
        <.icon name="hero-signal-micro" class="size-4" />
        <span>Network</span>
      </.link>

      <div class="my-1 mx-2" style="border-top:1px solid var(--border)"></div>

      <div
        class="px-2 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider"
        style="color:var(--fg-dim)"
      >
        Agents
      </div>

      <div
        class="nav-item active"
        style="border-left:2px solid var(--color-ef-green);padding-left:6px"
      >
        <.icon name="hero-users-micro" class="size-4" />
        <span class="flex-1">All Agents</span>
        <span
          class="text-[10px] font-mono px-1.5 rounded ml-auto"
          style="background:var(--bg-2);color:var(--fg-dim)"
        >
          {@agent_count}
        </span>
      </div>

      <.link navigate="/sessions" class="nav-item">
        <.icon name="hero-envelope-micro" class="size-4" />
        <span>Inboxes</span>
      </.link>

      <div class="my-1 mx-2" style="border-top:1px solid var(--border)"></div>

      <div
        class="px-2 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider"
        style="color:var(--fg-dim)"
      >
        Demo
      </div>

      <.link navigate="/network" class="nav-item">
        <.icon name="hero-presentation-chart-bar-micro" class="size-4" />
        <span>Network Demo</span>
      </.link>

      <.link navigate="/demo" class="nav-item">
        <.icon name="hero-link-micro" class="size-4" />
        <span>Join</span>
      </.link>

      <div class="flex-1"></div>

      <.link navigate="/settings" class="nav-item">
        <.icon name="hero-cog-6-tooth-micro" class="size-4" />
        <span>Settings</span>
      </.link>

      <a
        href="https://github.com/ihorkatkov/viche"
        target="_blank"
        rel="noopener"
        class="nav-item mb-2"
      >
        <.icon name="hero-code-bracket-micro" class="size-4" />
        <span>GitHub</span>
      </a>
    </nav>
  </aside>

  <%!-- MAIN --%>
  <main class="flex-1 flex flex-col overflow-hidden">
    <%!-- TOPBAR --%>
    <div
      class="h-[50px] flex items-center px-5 gap-3 border-b flex-shrink-0"
      style="background:var(--bg-1);border-color:var(--border)"
    >
      <span class="text-[15px] font-semibold" style="color:var(--fg)">Agents</span>
      <span class="text-[13px]" style="color:var(--fg-dim)">/ all</span>
      <div class="flex-1"></div>
      <span class="flex items-center gap-1.5 text-[11px]" style="color:var(--color-ef-green)">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ef-green)] animate-pulse inline-block">
        </span>
        Live
      </span>
      <Layouts.theme_toggle />
    </div>

    <%!-- SEARCH / FILTER BAR --%>
    <div class="flex items-center p-3 gap-3" style="border-bottom:1px solid var(--border)">
      <form phx-change="search" class="flex-1">
        <input
          type="text"
          name="value"
          value={@query}
          phx-debounce="200"
          placeholder="Search by name or capability..."
          class="w-full rounded-lg px-3 py-1.5 text-sm outline-none"
          style="background:var(--bg-2);color:var(--fg);border:1px solid var(--border)"
        />
      </form>

      <%= for {label, value} <- [{"All", "all"}, {"Online", "online"}, {"Offline", "offline"}] do %>
        <button
          phx-click="filter"
          phx-value-status={value}
          class="text-[11px] px-3 py-1 rounded-full font-medium transition-colors"
          style={
            if @filter == String.to_atom(value),
              do:
                "background:color-mix(in srgb,var(--color-ef-green) 20%,transparent);color:var(--color-ef-green);border:1px solid var(--color-ef-green)",
              else: "background:var(--bg-2);color:var(--fg-dim);border:1px solid var(--border)"
          }
        >
          {label}
        </button>
      <% end %>
    </div>

    <%!-- CONTENT --%>
    <div class="flex-1 overflow-y-auto" style="background:var(--bg)">
      <%!-- Table header --%>
      <div
        class="grid grid-cols-[28px_1fr_auto_90px_52px_80px_70px] gap-3 items-center px-4 py-2 text-[10px] font-semibold uppercase tracking-wide"
        style="background:var(--bg-2);color:var(--fg-dim)"
      >
        <span></span>
        <span>Agent</span>
        <span>Capabilities</span>
        <span>Status</span>
        <span>Queue</span>
        <span>Last seen</span>
        <span>Registry</span>
      </div>

      <%!-- Table rows --%>
      <%= if @agents == [] do %>
        <div class="px-4 py-12 text-center text-[12px]" style="color:var(--fg-dim)">
          No agents match the current filters.
        </div>
      <% else %>
        <%= for agent <- @agents do %>
          <% avatar_colors = [
            "var(--color-ef-green)",
            "var(--color-ef-blue)",
            "var(--color-ef-purple)",
            "var(--color-ef-yellow)",
            "var(--color-ef-aqua)"
          ]

          avatar_color = Enum.at(avatar_colors, rem(:erlang.phash2(agent.name), 5))
          initial = agent.name |> String.first() |> String.upcase() %>
          <div
            phx-click="select_agent"
            phx-value-id={agent.id}
            class="grid grid-cols-[28px_1fr_auto_90px_52px_80px_70px] gap-3 items-center px-4 py-2.5 cursor-pointer transition-colors"
            style="border-top:1px solid var(--border)"
          >
            <%!-- Avatar --%>
            <div
              class="w-7 h-7 rounded-md flex items-center justify-center text-[11px] font-bold flex-shrink-0"
              style={"background:color-mix(in srgb, #{avatar_color} 20%, transparent);color:#{avatar_color}"}
            >
              {initial}
            </div>

            <%!-- Name + ID --%>
            <div class="min-w-0">
              <div class="text-[13px] font-medium truncate" style="color:var(--fg)">
                {agent.name}
              </div>
              <div class="text-[10px] font-mono truncate" style="color:var(--fg-dim)">
                {String.slice(agent.id, 0, 8)}
              </div>
            </div>

            <%!-- Capabilities --%>
            <div class="flex gap-1 flex-wrap">
              <%= for cap <- agent.capabilities do %>
                <span class="cap-tag">{cap}</span>
              <% end %>
            </div>

            <%!-- Status --%>
            <span class={"status-pill #{if agent.status == :online, do: "idle", else: "offline"}"}>
              {agent.status}
            </span>

            <%!-- Queue --%>
            <span class="text-[12px] font-mono" style="color:var(--fg-dim)">
              {agent.queue_depth}
            </span>

            <%!-- Last seen --%>
            <span class="text-[11px]" style="color:var(--fg-dim)">
              {VicheWeb.LiveHelpers.format_last_seen(agent.last_activity)}
            </span>

            <%!-- Registry --%>
            <span class="text-[11px]" style="color:var(--fg-dim)">global</span>
          </div>
        <% end %>
      <% end %>

      <%!-- Footer --%>
      <div
        class="px-3 py-3 text-[11px]"
        style="color:var(--fg-dim);border-top:1px solid var(--border)"
      >
        Showing {length(@agents)} of {@agent_count} agents
      </div>
    </div>

    <%!-- STATUS BAR --%>
    <div
      class="h-6 flex items-center px-4 gap-3 text-[10px] font-mono border-t flex-shrink-0"
      style="background:var(--bg-1);border-color:var(--border);color:var(--fg-dim)"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ef-green)] animate-pulse inline-block">
      </span>
      ws://viche.ai/socket <span class="opacity-30">|</span>
      registry: public <span class="opacity-30">|</span>
      {@agent_count} agents &middot; {@online_count} online <span class="opacity-30">|</span>
      {@messages_today} messages today
    </div>
  </main>
</div>
