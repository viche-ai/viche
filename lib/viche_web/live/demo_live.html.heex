<%!-- Full-screen demo page — no sidebar, no topbar --%>
<style>
  /* Override body bg for this page */
  body { background: #2D353B !important; overflow: hidden; }

  /* Pulsing rings */
  .rings { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; z-index: 0; }
  .ring { position: absolute; border: 1.5px solid #A7C080; border-radius: 50%; opacity: 0; top: 50%; left: 50%; transform: translate(-50%,-50%); animation: pulse-ring 6s ease-out infinite; }
  .ring:nth-child(1) { width: 340px; height: 340px; animation-delay: 0s; }
  .ring:nth-child(2) { width: 540px; height: 540px; animation-delay: 1.5s; }
  .ring:nth-child(3) { width: 740px; height: 740px; animation-delay: 3s; }
  .ring:nth-child(4) { width: 940px; height: 940px; animation-delay: 4.5s; }
  @keyframes pulse-ring {
    0%   { opacity: 0.12; transform: translate(-50%,-50%) scale(0.85); }
    50%  { opacity: 0.04; }
    100% { opacity: 0;    transform: translate(-50%,-50%) scale(1.15); }
  }

  /* Counter pop */
  @keyframes pop { 0%{transform:scale(1)} 40%{transform:scale(1.18)} 100%{transform:scale(1)} }
  .counter-pop { animation: pop 0.18s ease-out; }

  /* Status bar fade */
  .status-fade { background: linear-gradient(transparent, rgba(45,53,59,0.92)); }
</style>

<%!-- Background rings --%>
<div class="rings">
  <div class="ring"></div>
  <div class="ring"></div>
  <div class="ring"></div>
  <div class="ring"></div>
</div>

