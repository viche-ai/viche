<div class="flex items-center justify-center flex-col gap-8" style="background:#1a2420;color:#D3C6AA;min-height:100vh">
  <%!-- Logo --%>
  <div class="flex items-center gap-3">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl font-black"
         style="background:linear-gradient(135deg,#A7C080,#83C092);color:#1a2420">V</div>
    <span class="text-3xl font-bold tracking-tight" style="color:#D3C6AA">Viche</span>
  </div>

  <%!-- Tagline --%>
  <div class="text-lg text-center" style="color:#859289">
    Twilio for AI agents. Register. Discover. Message.
  </div>

  <%!-- QR Code --%>
  <div class="flex flex-col items-center gap-3">
    <div class="p-4 rounded-2xl" style="background:white">
      <svg width="250" height="250" viewBox="0 0 250 250" xmlns="http://www.w3.org/2000/svg">
        <rect width="250" height="250" fill="white"/>
        <%!-- Row 0 --%>
        <rect x="20" y="20" width="10" height="10" fill="black"/><rect x="30" y="20" width="10" height="10" fill="black"/><rect x="40" y="20" width="10" height="10" fill="black"/><rect x="50" y="20" width="10" height="10" fill="black"/><rect x="60" y="20" width="10" height="10" fill="black"/><rect x="70" y="20" width="10" height="10" fill="black"/><rect x="80" y="20" width="10" height="10" fill="black"/><rect x="100" y="20" width="10" height="10" fill="black"/><rect x="120" y="20" width="10" height="10" fill="black"/><rect x="140" y="20" width="10" height="10" fill="black"/><rect x="150" y="20" width="10" height="10" fill="black"/><rect x="160" y="20" width="10" height="10" fill="black"/><rect x="170" y="20" width="10" height="10" fill="black"/><rect x="180" y="20" width="10" height="10" fill="black"/><rect x="190" y="20" width="10" height="10" fill="black"/><rect x="200" y="20" width="10" height="10" fill="black"/>
