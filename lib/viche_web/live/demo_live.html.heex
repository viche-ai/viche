  <%!-- Join counter --%>
  <div class="text-center">
    <div class="text-6xl font-black tabular-nums" style="color:#A7C080">{@join_count}</div>
    <div class="text-lg mt-1" style="color:#859289">people connected</div>
  </div>
  <div class="text-sm" style="color:#859289">Scan to connect your agent to the network</div>

  <%!-- Status bar --%>
  <div class="text-xs font-mono flex items-center gap-3 mt-8" style="color:#859289">
    <span class="w-1.5 h-1.5 rounded-full inline-block animate-pulse" style="background:#A7C080"></span>
    24 agents online · 1,247 messages · ws connected
  </div>
</div>
