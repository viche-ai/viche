  <%!-- Join counter — LiveView pushes CSS class on increment via phx-update --%>
  <div class="text-center">
    <div
      id="join-counter"
      class="text-6xl font-black tabular-nums inline-block"
      style="color:#A7C080"
      phx-hook="CounterPop"
    >
      {@join_count}
    </div>
    <span class="text-2xl font-medium ml-2" style="color:#D3C6AA">
      {if @join_count == 1, do: "person", else: "people"} connected
    </span>
    <div class="text-sm mt-2" style="color:#859289">
      Scan to connect your agent to the network
    </div>
  </div>
</div>

<%!-- Fixed status bar --%>
<div
  class="status-fade fixed bottom-0 left-0 right-0 flex items-center justify-center gap-4 pb-4 pt-8"
  style="font-size:12px;color:#859289"
>
  <span>
    <span
      class="w-1.5 h-1.5 rounded-full inline-block mr-1.5 animate-pulse"
      style="background:#A7C080"
    >
    </span>
    ws connected
  </span>
  <span style="opacity:0.3">·</span>
  <span>{@agent_count} agents online</span>
  <span style="opacity:0.3">·</span>
  <span>{@messages_today} messages</span>
</div>
